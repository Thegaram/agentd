FROM debian:trixie-slim

# Capture build date early so it only changes on --no-cache rebuilds
# (Docker caches this layer, so the date stays fixed until cache is busted)
RUN date -u +%Y%m%d > /tmp/build-date

LABEL devcontainer.metadata='[{"remoteUser":"agent","workspaceFolder":"/workspace"}]'

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    git \
    curl \
    wget \
    jq \
    tmux \
    ncurses-term \
    locales \
    # Build essentials (C/C++ toolchain, linker, make)
    build-essential \
    cmake \
    pkg-config \
    # Common dev libraries
    libssl-dev \
    libffi-dev \
    zlib1g-dev \
    libbz2-dev \
    libreadline-dev \
    libsqlite3-dev \
    libncurses-dev \
    libxml2-dev \
    libxslt-dev \
    libyaml-dev \
    libcurl4-openssl-dev \
    libpq-dev \
    # Python (full dev headers)
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    python-is-python3 \
    # Search tools
    ripgrep \
    fd-find \
    # Misc
    unzip \
    zip \
    file \
    less \
    htop \
    strace \
    openssh-client \
    tree \
    patch \
    sqlite3 \
    shellcheck \
    xz-utils \
    xxd \
    postgresql-client \
  && rm -rf /var/lib/apt/lists/* \
  && sed -i '/en_US.UTF-8/s/^# //' /etc/locale.gen && locale-gen

# Install Node.js 22 LTS
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
  && apt-get install -y nodejs \
  && rm -rf /var/lib/apt/lists/*

# fd-find installs as fdfind on Debian; alias it
RUN ln -s "$(which fdfind)" /usr/local/bin/fd 2>/dev/null || true

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
  && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    > /etc/apt/sources.list.d/github-cli.list \
  && apt-get update \
  && apt-get install -y gh \
  && rm -rf /var/lib/apt/lists/*

# Install logcli (Grafana Loki CLI)
RUN ARCH=$(dpkg --print-architecture) \
  && curl -fsSL "https://github.com/grafana/loki/releases/latest/download/logcli-linux-${ARCH}.zip" -o /tmp/logcli.zip \
  && unzip /tmp/logcli.zip -d /usr/local/bin \
  && chmod +x /usr/local/bin/logcli-linux-${ARCH} \
  && mv /usr/local/bin/logcli-linux-${ARCH} /usr/local/bin/logcli \
  && rm /tmp/logcli.zip

# Install yq (YAML/JSON/XML processor, like jq but for YAML)
RUN ARCH=$(dpkg --print-architecture) \
  && curl -fsSL "https://github.com/mikefarah/yq/releases/latest/download/yq_linux_${ARCH}" -o /usr/local/bin/yq \
  && chmod +x /usr/local/bin/yq

# Non-root user (created early so Rust installs to agent's home)
RUN useradd -m -s /bin/bash agent
RUN mkdir -p /agentd /workspace \
  && chown -R agent:agent /agentd /workspace

# Install Go
ENV GOLANG_VERSION=1.24.1
RUN curl -fsSL "https://go.dev/dl/go${GOLANG_VERSION}.linux-$(dpkg --print-architecture).tar.gz" \
    | tar -C /usr/local -xz
ENV PATH="/usr/local/go/bin:${PATH}"

# Install Rust (as agent user, installs to ~/.cargo)
USER agent
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --default-toolchain stable --profile minimal \
  && rm -rf ~/.rustup/toolchains/*/share/doc
ENV PATH="/home/agent/.cargo/bin:${PATH}"

# Install Foundry (forge, cast, anvil, chisel)
RUN curl -L https://foundry.paradigm.xyz | bash \
  && /home/agent/.foundry/bin/foundryup
ENV PATH="/home/agent/.foundry/bin:${PATH}"

# Install solc via svm (platform-aware Solidity version manager)
ENV PATH="/home/agent/.local/bin:${PATH}"
RUN cargo install svm-rs \
  && svm install 0.8.28 \
  && svm use 0.8.28 \
  && rm -rf ~/.cargo/registry ~/.cargo/git

# Install gopls (Go LSP server)
ENV GOPATH="/home/agent/go"
ENV PATH="/home/agent/go/bin:${PATH}"
RUN go install golang.org/x/tools/gopls@latest

USER root

# Install uv (Python package manager)
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh

# JS package managers, tools, and LSP servers
RUN npm install -g pnpm yarn trash-cli @upstash/context7-mcp \
    typescript-language-server typescript pyright

# Install rust-analyzer
RUN ARCH=$(dpkg --print-architecture) \
  && case "$ARCH" in amd64) RA_ARCH="x86_64-unknown-linux-gnu" ;; arm64) RA_ARCH="aarch64-unknown-linux-gnu" ;; *) RA_ARCH="" ;; esac \
  && if [ -n "$RA_ARCH" ]; then \
       curl -fsSL "https://github.com/rust-lang/rust-analyzer/releases/latest/download/rust-analyzer-${RA_ARCH}.gz" \
       | gunzip > /usr/local/bin/rust-analyzer \
       && chmod +x /usr/local/bin/rust-analyzer; \
     fi

# Git identity for commits inside containers
RUN git config --system user.name "agentd" \
  && git config --system user.email "agentd@localhost"

# agentd build version (commit hash + build date)
ARG AGENTD_COMMIT=dev
RUN echo "${AGENTD_COMMIT}-$(cat /tmp/build-date)" > /agentd/version && rm -f /tmp/build-date

# Copy shared scripts (agent-specific check-auth.sh is added per-agent)
COPY set-statusbar.sh copy-clipboard.sh /agentd/
RUN chmod +x /agentd/set-statusbar.sh /agentd/copy-clipboard.sh

# Base shell prompt (agent Dockerfiles append credential cleanup)
RUN printf '%s\n' \
    'PS1="\[\e[32m\]agent@\h\[\e[0m\]:\[\e[34m\]\w\[\e[0m\]\$ "' \
    '# Source mounted secrets (if any)' \
    'if [ -d /run/secrets ]; then for _f in /run/secrets/*.env; do [ -f "$_f" ] && set -a && . "$_f" && set +a; done; unset _f; fi' \
    > /home/agent/.bashrc \
  && chown agent:agent /home/agent/.bashrc

WORKDIR /workspace

# tmux config: truecolor passthrough, theme detection, mouse
RUN printf '%s\n' \
    'set -g default-terminal "tmux-256color"' \
    'set -as terminal-features ",xterm*:clipboard:RGB"' \
    'set -as terminal-features ",tmux*:clipboard:RGB"' \
    'set -as terminal-features ",screen*:clipboard"' \
    'set -g allow-passthrough on' \
    'set -g copy-command "bash /agentd/copy-clipboard.sh"' \
    'set -g mouse on' \
    > /home/agent/.tmux.conf \
  && chown agent:agent /home/agent/.tmux.conf

ENV PATH="/home/agent/.local/bin:/home/agent/.foundry/bin:/home/agent/.cargo/bin:/usr/local/go/bin:${PATH}"
ENV WORKSPACE_DIR=/workspace
ENV TERM=xterm-256color
ENV COLORTERM=truecolor
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV NODE_OPTIONS="--max-old-space-size=4096"

USER agent
ENTRYPOINT ["bash"]
