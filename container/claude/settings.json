{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Bash(dd if=*)",
      "Bash(wget *|bash*)",
      "Bash(wget *| bash*)",
      "Bash(curl *|bash*)",
      "Bash(curl *| bash*)",
      "Bash(git push --force*)",
      "Bash(git push *--force*)",
      "Bash(git reset --hard*)",
      "Bash(gh pr create*)",
      "Bash(gh pr close*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr comment*)",
      "Bash(gh pr review*)",
      "Bash(gh pr ready*)",
      "Bash(gh pr reopen*)",
      "Bash(gh issue create*)",
      "Bash(gh issue close*)",
      "Bash(gh issue edit*)",
      "Bash(gh issue comment*)",
      "Bash(gh issue delete*)",
      "Bash(gh issue reopen*)",
      "Bash(gh repo create*)",
      "Bash(gh repo delete*)",
      "Bash(gh repo fork*)",
      "Bash(gh repo rename*)",
      "Bash(gh repo archive*)",
      "Bash(gh release create*)",
      "Bash(gh release delete*)",
      "Bash(gh release edit*)",
      "Bash(gh label create*)",
      "Bash(gh label delete*)",
      "Bash(gh label edit*)",
      "Bash(gh api -X POST*)",
      "Bash(gh api -X PUT*)",
      "Bash(gh api -X PATCH*)",
      "Bash(gh api -X DELETE*)",
      "Bash(gh api --method POST*)",
      "Bash(gh api --method PUT*)",
      "Bash(gh api --method PATCH*)",
      "Bash(gh api --method DELETE*)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.git-credentials)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "autoMemoryEnabled": false,
  "enableAllProjectMcpServers": false,
  "alwaysThinkingEnabled": true,
  "attribution": {"commit": "", "pr": ""},
  "env": {
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command'); if echo \"$CMD\" | grep -qiE '(^|;[[:space:]]*|&&[[:space:]]*|[|][|][[:space:]]*|[|][[:space:]]*)rm[[:space:]]' && echo \"$CMD\" | grep -qiE '(^|[[:space:]])-[a-zA-Z]*[rR]|--recursive' && echo \"$CMD\" | grep -qiE '(^|[[:space:]])-[a-zA-Z]*[fF]|--force'; then echo 'BLOCKED: Use trash instead of rm -rf' >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command'); if echo \"$CMD\" | grep -qE 'git[[:space:]]+push.*(main|master)'; then echo 'BLOCKED: Use feature branches, not direct push to main' >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command'); if echo \"$CMD\" | grep -qE '(^|;|&&|\\|\\||\\|)\\s*gh\\s+' && ! echo \"$CMD\" | grep -qE '(^|;|&&|\\|\\||\\|)\\s*gh\\s+(pr\\s+(view|diff|list|status|checks|checkout)|issue\\s+(view|list|status)|repo\\s+(view|clone|list)|run\\s+(view|list|watch)|release\\s+(view|list)|api\\s+(repos/|/repos|orgs/)|search\\s|browse|gist\\s+(view|list)|status)'; then echo 'BLOCKED: only read-only gh commands are allowed (view, diff, list, status, checks, checkout, clone, search, browse)' >&2; exit 2; fi"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/agent/.claude/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/agent/.claude/statusline.sh"
  }
}
