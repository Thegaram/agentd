#compdef agentd

# Session-label completion is why agentd ships this static file instead of the
# framework's built-in `agentd completions zsh`: incur's dynamic completion has
# no runtime arg-value hook, so it can't read labels from state.json. Everything
# else here mirrors the CLI commands/flags — keep it in sync when those change.

_agentd_sessions() {
  local state_file="${AGENTD_HOME:-$HOME/.agentd}/state.json"
  [[ -f "$state_file" ]] || return
  local -a labels
  labels=("${(@f)$(jq -r '.sessions[].label' "$state_file" 2>/dev/null)}")
  compadd -a labels
}

# --persona accepts a reusable persona name (~/.agentd/persona/<name>.md) or a
# file path, so offer both the bare names and filesystem paths. `(N)` is
# nullglob (no matches → empty, no error); `${f:t:r}` takes the basename and
# strips the .md extension, leaving the name the CLI resolves.
_agentd_personas() {
  local persona_dir="${AGENTD_HOME:-$HOME/.agentd}/persona"
  local -a names
  local f
  for f in "$persona_dir"/*.md(N); do
    names+=("${f:t:r}")
  done
  (( ${#names} )) && _describe -t personas 'reusable persona' names
  _files
}

_agentd() {
  local -a commands=(
    'ls:List all active sessions'
    'cancel:Cancel a session and remove its container'
    'shell:Sandboxed coding agent session (label defaults to current folder name)'
    'code:Open a running session in VS Code (Dev Containers)'
    'serve:Read-only web dashboard for active sessions (localhost only)'
    'completions:Print the shell completion script'
  )

  if (( CURRENT == 2 )); then
    _describe 'command' commands
    return
  fi

  case "${words[2]}" in
    cancel)
      (( CURRENT == 3 )) && _agentd_sessions
      ;;
    code)
      (( CURRENT == 3 )) && _agentd_sessions
      ;;
    ls)
      _arguments '--watch[Live-updating dashboard (refreshes every 2s)]'
      ;;
    serve)
      _arguments \
        '--port[Port to bind on 127.0.0.1 (default 8787)]:port:' \
        "--skip-open[Don't open the dashboard in your browser (opens by default)]"
      ;;
    completions)
      (( CURRENT == 3 )) && compadd bash fish nushell zsh
      ;;
    shell)
      _arguments \
        '1:session label:_agentd_sessions' \
        '--claude[Use Claude Code backend (default)]' \
        '--codex[Use OpenAI Codex backend]' \
        '--aider[Use aider backend (local Ollama)]' \
        '--pi[Use pi coding agent backend]' \
        '*--mount[Mount paths, replaces default cwd mount (host\:container)]:mount path:_files' \
        '*--secret[Secret scopes to pass (defaults to agent-specific scope)]:scope:' \
        '--model[Model override (agent-specific, e.g. opus, gpt-5.4)]:model:' \
        '--rm[Remove container when session ends]' \
        "--skip-mount[Don't mount current directory]" \
        '*--port[Port mappings \[host\:\]container (replaces default 3000)]:port:' \
        "--skip-ports[Don't publish any ports]" \
        '--persona[Reusable persona name (~/.agentd/persona/<name>.md) or a file path]:persona:_agentd_personas' \
        "--no-persona[Don't mount any persona/instructions file]" \
        '--dry-run[Print the Docker command without executing]'
      ;;
  esac
}

_agentd "$@"
